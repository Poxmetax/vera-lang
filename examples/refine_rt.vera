// VERA Phase 1 — refinement types checked at runtime (SMT is Phase 2)

fn clamp(x: Int, lo: Int, hi: Int) -> {r: Int | r >= lo && r <= hi}
    requires lo <= hi
{
    if x < lo {
        lo
    } else {
        if x > hi {
            hi
        } else {
            x
        }
    }
}

fn main(console: Console) -> Unit
    uses {console}
{
    console.print(clamp(5, 0, 10).show());
    console.print(clamp(-3, 0, 10).show());
    console.print(clamp(99, 0, 10).show());
}
